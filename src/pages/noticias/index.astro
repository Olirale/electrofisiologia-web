---
import Layout from '../../layouts/Layout.astro';
import '../../styles/noticias.css';

import { getCollection } from 'astro:content';

const posts = await getCollection('noticias');

// Los ordenamos por fecha (de más reciente a más antiguo)
const sortedPosts = posts.sort((a, b) =>
    new Date(b.data.fecha).getTime() - new Date(a.data.fecha).getTime()
);
const base = import.meta.env.BASE_URL;
const fechaOpciones = { day: "2-digit", month: 'long', year: 'numeric' }

---

<Layout title="Archivo de Noticias · Unidad de Electrofisiología">
    <section class="news-archive-section">
        <div class="container">
            <div class="section-header">
                <span class="section-eyebrow">Comunicación</span>
                <h1 class="section-title">Actualidad y Noticias</h1>
                <div class="gold-line"></div>
            </div>

            <div class="news-grid-archive">
                {sortedPosts.map(post => (
                        <a href={`${base}/noticias/${post.id}`} class="news-card-archive">
                            <div class="news-card-img">
                                {post.data.icono || '📰'}
                            </div>
                            <div class="news-card-content">
                                <span class="tag">{post.data.tipo}</span>
                                <h2>{post.data.title}</h2>
                                <p>{post.data.resumen}</p>
                                <div class="news-card-footer">
                                    <span class="meta-sm">📅 {post.data.fecha.toLocaleDateString('es-ES', fechaOpciones)}</span>
                                    <span class="btn-text">Leer más</span>
                                </div>
                            </div>
                        </a>
                ))}
            </div>

            {sortedPosts.length === 0 && (
                    <p style="text-align: center; color: var(--gray); padding: 4rem;">
                        No hay noticias publicadas en este momento.
                    </p>
            )}
        </div>
    </section>
</Layout>