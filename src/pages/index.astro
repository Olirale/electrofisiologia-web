---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import '../styles/index.css';

import { getCollection } from 'astro:content';

const posts = await getCollection('noticias');
const casosAll = await getCollection('casos');
const casosHome = casosAll.slice(0, 5);

const sortedPosts = posts.sort((a, b) =>
	new Date(b.data.fecha).getTime() - new Date(a.data.fecha).getTime()
);

const noticiaDestacada = sortedPosts[0];
const restoNoticias = sortedPosts.slice(1, 3);

import videos from '../data/videos.json';
import equipo from '../data/equipo.json';

const videosHome = videos.slice(0, 4);
const base = import.meta.env.BASE_URL;

const carpetaImagenes = '/src/assets/img/equipo/';
const imagenes = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/img/equipo/*.{jpeg,jpg,png,webp}',
	{ eager: true });
---

<Layout title="Unidad de Electrofisiología · CHUAC">

	<section class="hero">
		<div class="hero-content">
			<div class="hero-eyebrow">Complejo Hospitalario Universitario de A Coruña</div>
			<h1 class="hero-title">Unidad de<br/>Electrofisiología</h1>
			<p class="hero-sub">Líderes en el tratamiento de arritmias complejas, combinando tecnología de vanguardia con un enfoque humano y docente.</p>
			<div class="hero-cta">
				<a href="#contacto" class="btn-outline">Contactar</a>
			</div>
		</div>
	</section>

	<section id="noticias" class="container">
		<div class="section-header">
			<span class="section-eyebrow">Actualidad</span>
			<h2 class="section-title">Últimas Noticias</h2>
			<div class="gold-line"></div>
		</div>

		<div class="news-layout">
			<article class="news-featured">
				<div class="news-icon">{noticiaDestacada.data.icono}</div>
				<div class="news-body">
					<a href={`${base}/noticias/${noticiaDestacada.id}`} class="news-card-archive">
						<span class="tag">{noticiaDestacada.data.tipo}</span>
						<h3>{noticiaDestacada.data.title}</h3>
						<p>{noticiaDestacada.data.resumen}</p>
						<div class="meta">📅 {noticiaDestacada.data.lugar} {noticiaDestacada.data.lugar && `· 🏥 ${noticiaDestacada.data.fecha}`}</div>
					</a>
				</div>
			</article>

			<div class="news-sidebar">
				{restoNoticias.map(noticia => (
					<article class="news-card-mini">
						<div class="news-mini-icon">{noticia.data.icono}</div>
						<div class="news-mini-content">
							<a href={`${base}/noticias/${noticia.id}`} class="news-card-archive">
								<span class="tag-sm">{noticia.data.tipo}</span>
								<h4>{noticia.data.title}</h4>
								<p>{noticia.data.resumen}</p>
								<span class="meta-sm">{noticia.data.fecha}</span>
							</a>
						</div>
					</article>
				))}
			</div>
		</div>

		<div class="center-link">
			<a href={`${base}/noticias/`} class="view-all">Ver todas las noticias →</a>
		</div>
	</section>

	<section id="casos" class="bg-offwhite">
		<div class="container">
			<div class="section-header">
				<span class="section-eyebrow">Área Docente</span>
				<h2 class="section-title">Casos Clínicos Recientes</h2>
				<div class="gold-line"></div>
			</div>

			<section class="casos-grid">
				{casosHome.map(caso => (
					<article class="caso-card">
						<div class="caso-header">
							<span class="caso-icon">{caso.data.icono}</span>
							<span class="caso-number">#{caso.data.numero}</span>
						</div>
						<div class="caso-body">
							<span class="caso-type">{caso.data.tipo}</span>
							<h3>{caso.data.title}</h3>
							<p>{caso.data.resumen}</p>
						</div>
						<div class="caso-footer">
							<a href={`${base}/casos/${caso.id}`} class="btn-text">Ver detalles del caso</a>
						</div>
					</article>
				))}
			</section>
			<div class="center-link">
				<a href={`${base}/fellowship/`} class="btn-primary">Ver Programa Completo</a>
			</div>
		</div>
	</section>

	<section id="fellowship" class="container">
		<div class="section-header">
			<span class="section-eyebrow">Formación Avanzada</span>
			<h2 class="section-title">Programa de Fellowship</h2>
			<div class="gold-line"></div>
		</div>

		<div class="news-layout">
			<article class="news-featured">
				<div class="news-icon">🎓</div>
				<div class="news-body">
					<div class="news-card-archive">
						<span class="tag">Postgrado</span>
						<h3>Especialización en Electrofisiología Clínica</h3>
						<p>Formación integral para cardiólogos en el diagnóstico y tratamiento de arritmias, con acceso a tecnología de navegación 3D y laboratorio de última generación.</p>
						<div class="hero-cta" style="margin-top: 20px;">
							<a href={`${base}/fellowship/`} class="btn-primary">Ver Programa Completo</a>
						</div>
					</div>
				</div>
			</article>
		</div>
	</section>

	<section id="videos" class="bg-navy">
		<div class="container">
			<div class="section-header invert">
				<span class="section-eyebrow">Pacientes</span>
				<h2 class="section-title">Aula Virtual</h2>
				<div class="gold-line"></div>
			</div>

			<div class="videos-grid">
				{videosHome.map(video => (
					<div class="video-card">
						<div class="video-thumb">
							<iframe
								src={video.url}
								title={video.titulo}
								loading="lazy"
								allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
								allowfullscreen>
							</iframe>
						</div>
						<div class="video-info">
							<span class="tag-video">{video.tipo}</span>
							<h4>{video.titulo}</h4>
							<p>{video.resumen}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="equipo" class="container">
		<div class="section-header">
			<span class="section-eyebrow">Profesionales</span>
			<h2 class="section-title">Nuestro Equipo</h2>
			<div class="gold-line"></div>
		</div>

		<section class="team-grid">
			{equipo.map(persona => {
				const rutaImagen = persona.imagen ? `${carpetaImagenes}${persona.imagen}` : null;
				const imagenData = rutaImagen && imagenes[rutaImagen] ? imagenes[rutaImagen].default : null;
				const letraPlaceholder = persona.nombre.replace('Dr/a. ', '').charAt(0);

				return (
					<div class="team-card">
						<div class="team-image-container">
							{imagenData ? (
								<Image
									src={imagenData}
									alt={`Retrato de ${persona.nombre}`}
									width={150}
									height={150}
									class="team-img"
								/>
							) : (
								<div class="team-placeholder">{letraPlaceholder}</div>
							)}
						</div>
						<div class="team-info">
							<h3>{persona.nombre}</h3>
							<span class="role">{persona.puesto}</span>
							<p>{persona.resumen}</p>
						</div>
					</div>
				);
			})}
		</section>
	</section>

	<section id="contacto" class="bg-offwhite">
		<div class="container contact-wrapper">
			<div class="contact-info">
				<h2 class="section-title">Contacto</h2>
				<div class="gold-line"></div>
				<p>Estamos situados en el Complejo Hospitalario Universitario de A Coruña (CHUAC).</p>
				<div class="contact-details">
					<div class="detail-item">
						<strong>📍 Ubicación Física</strong>
						<p>As Xubias de Arriba, 84, 15006 A Coruña<br/>Planta 2 - Área de Cardiología</p>
					</div>
					<div class="detail-item">
						<strong>📞 Centralita Hospital</strong>
						<p>981 17 80 00</p>
					</div>
				</div>
			</div>
			<form class="contact-form" action="#" method="POST">
				<div class="form-group">
					<label for="name">Nombre</label>
					<input type="text" id="name" name="name" required />
				</div>
				<div class="form-group">
					<label for="email">Correo Electrónico</label>
					<input type="email" id="email" name="email" required />
				</div>
				<div class="form-group">
					<label for="message">Mensaje</label>
					<textarea id="message" name="message" rows="4"></textarea>
				</div>
				<button type="submit" class="btn-primary">Enviar consulta</button>
			</form>
		</div>
	</section>

</Layout>
