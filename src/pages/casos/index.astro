---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
// Reutilizamos los estilos para que la web sea coherente
import '../../styles/casos.css'
import '../../styles/noticias.css';
import '../../styles/noticia.css';

// 1. Obtener todos los casos y ordenarlos por el campo 'numero' (opcional)
const cases = await getCollection('casos');
const casesOrdenados = cases.sort((a, b) => b.data.numero - a.data.numero);

// 2. Preparar la URL base para los enlaces
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const title = "Casos Clínicos | Unidad de Electrofisiología";

---

<Layout title={title}>
    <section class="news-hero">
        <div class="container">
            <span class="section-badge">Formación Médica</span>
            <h1 class="section-title">Casos <span>Clínicos</span></h1>
            <p class="section-description">
                Análisis detallados de procedimientos electrofisiológicos reales,
                técnicas de mapeo y resolución de complicaciones.
            </p>
        </div>
    </section>

    <section class="news-grid-section">
        <div class="container">
            <div class="news-grid">
                {casesOrdenados.map((caso) => (
                        <article class="news-card">
                            <div class="news-card-content">
                                <div class="news-card-meta">
                                    <span class="news-card-icon">{caso.data.icono || '🩺'}</span>
                                    <span class="news-tag">{caso.data.tipo}</span>
                                </div>

                                <h2 class="news-card-title">
                                    <a href={`${base}/casos/${caso.id}`}>
                                        {caso.data.title}
                                    </a>
                                </h2>

                                <p class="news-card-excerpt">
                                    {caso.data.resumen}
                                </p>

                                <div class="news-card-footer">
                                <span class="news-card-date">
                                    {new Date(caso.data.fecha).toLocaleDateString('es-ES', {
                                        month: 'long',
                                        year: 'numeric'
                                    })}
                                </span>
                                    <a href={`${base}/casos/${caso.id}`} class="read-more">
                                        Ver caso completo →
                                    </a>
                                </div>
                            </div>
                        </article>
                ))}
            </div>

            {casesOrdenados.length === 0 && (
                    <div class="no-results">
                        <p>Próximamente publicaremos nuevos casos clínicos.</p>
                    </div>
            )}
        </div>
    </section>
</Layout>
