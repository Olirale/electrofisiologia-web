---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import '../../styles/noticias.css';
import '../../styles/casos.css';

const cases = await getCollection('casos');
// Ordenamos por el campo 'numero' que añadimos antes
const casesOrdenados = cases.sort((a, b) => b.data.numero - a.data.numero);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Casos Clínicos | Unidad de Electrofisiología">
    <section class="news-hero">
        <div class="container">
            <span class="section-badge">Formación Médica</span>
            <h1 class="section-title">Casos <span>Clínicos</span></h1>
            <p class="section-description">
                Análisis detallados de procedimientos electrofisiológicos reales.
            </p>
        </div>
    </section>

    <section class="news-grid-section">
        <div class="container">
            <div class="news-grid-archive">
                {casesOrdenados.map((caso) => (
                        <article class="news-card-archive">
                            <div class="news-card-content">
                                <div>
                                    <span class="news-card-img">{caso.data.icono || '🩺'}</span>
                                    <span class="news-tag">{caso.data.tipo}</span>
                                </div>

                                <h2 class="news-card-title">
                                        {caso.data.title}
                                </h2>

                                <p class="news-card-excerpt">
                                    {caso.data.resumen}
                                </p>

                                <div class="news-card-footer">
                                    <span class="meta-sm">
                                        {new Date(caso.data.fecha).toLocaleDateString('es-ES', {
                                            month: 'long',
                                            year: 'numeric'
                                        })}
                                    </span>
                                    <a href={`${base}/casos/${caso.id}`} class="btn-text">
                                        Ver caso completo →
                                    </a>
                                </div>
                            </div>
                        </article>
                ))}
            </div>
        </div>
    </section>
</Layout>