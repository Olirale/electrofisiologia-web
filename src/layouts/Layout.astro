---
import '../styles/main.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL;


const navLinks = [
	{ href: `${base}/noticias`, label: "Noticias" },
	{ href: `${base}/casos`, label: "Casos" },
	{ href: `${base}/#videos`, label: "Pacientes" },
    { href: `${base}/#fellowship`, label: "Fellowship" },
	{ href: `${base}/#equipo`, label: "Equipo" },
	{ href: `${base}/#contacto`, label: "Contacto" },
];

---

<!DOCTYPE html>
<html lang="es">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<meta name="generator" content={Astro.generator} />
	<title>{title}</title>

	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Source+Sans+3:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>
<body>
<nav class="navbar" id="navbar">
	<div class="nav-container">
		<a href={`${base}/`}  class="nav-logo">
			<span class="logo-symbol">✚</span>
			<div class="logo-text">
				<span class="logo-main">ELECTROFISIOLOGÍA</span>
				<span class="logo-sub">CHUAC · A CORUÑA</span>
			</div>
		</a>

		<div class="nav-links">
			{navLinks.map(link => (
				<a href={link.href}>{link.label}</a>
			))}
		</div>
	</div>
</nav>

<main>
	<slot />
</main>

<footer class="footer">
	<div class="container footer-grid">
		<div class="footer-info">
			<div class="nav-logo invert">
				<span class="logo-symbol">✚</span>
				<div class="logo-text">
					<span class="logo-main">ELECTROFISIOLOGÍA</span>
					<span class="logo-sub">CHUAC · A CORUÑA</span>
				</div>
			</div>
			<p>Unidad de referencia para el tratamiento integral de arritmias.</p>
		</div>

		<div class="footer-contact">
			<h4>Contacto</h4>
			<p>Hospital Universitario A Coruña</p>
			<p>As Xubias de Arriba, 84 · 15006 A Coruña</p>
		</div>

		<div class="footer-links">
			<h4>Enlaces</h4>
			<a href="https://www.sergas.es" target="_blank">SERGAS</a>
			<a href="#">Área Coruña</a>
		</div>
	</div>
	<div class="footer-bottom">
		<p>&copy; {new Date().getFullYear()} Unidad de Electrofisiología CHUAC.</p>
	</div>
</footer>

<script>
	const nav = document.getElementById('navbar');
	window.addEventListener('scroll', () => {
		if (window.scrollY > 50) {
			nav?.classList.add('scrolled');
		} else {
			nav?.classList.remove('scrolled');
		}
	});
</script>
</body>
</html>
